# Tencent Cloud API credentials. Create a new key after rotating the exposed one.
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_APP_ID=
TENCENT_REGION=ap-chengdu

# SCF backend
SCF_FUNCTION_NAME=yijing-divine
SCF_NAMESPACE=default
SCF_VPC_ID=vpc-gunz4h4k
SCF_SUBNET_ID=subnet-nrlw5qgd
SCF_MEMORY_SIZE=256
SCF_TIMEOUT=120
SCF_INIT_TIMEOUT=30

# Backend runtime secrets and config
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DB_HOST=
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=yijing
JWT_SECRET=
JWT_EXPIRES_DAYS=7
DAILY_AI_LIMIT=10
BUILD_VERSION=public-deploy-20260609

# Set this after COS deployment, for example:
# CORS_ORIGINS=http://localhost:8081,https://<bucket>-<appid>.cos-website.ap-chengdu.myqcloud.com
CORS_ORIGINS=http://localhost:8081

# COS static website
COS_BUCKET=yijing-static
COS_INDEX_FILE=index.html
