# Cloudflare Worker runtime secrets
# Set production secrets with:
#   cd worker
#   npx wrangler secret put DEEPSEEK_API_KEY
#   npx wrangler secret put JWT_SECRET
DEEPSEEK_API_KEY=
JWT_SECRET=

# Cloudflare Worker runtime config
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
JWT_EXPIRES_DAYS=7
DAILY_AI_LIMIT=10
BUILD_VERSION=cloudflare-d1-local

# Allowed frontend origins for local and production API calls.
CORS_ORIGINS=http://localhost:8081,http://localhost:8787,https://qfeng.cloud,https://www.qfeng.cloud
